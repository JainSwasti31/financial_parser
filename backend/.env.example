PROJECT_NAME="AI Financial Document Parser"
API_V1_STR="/api/v1"
HOST="127.0.0.1"
PORT=8000

# PostgreSQL is recommended. SQLite may be used for a single-process local demo.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/financial_parser"
DB_CONNECT_TIMEOUT_SECONDS=10

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY="replace-with-a-long-random-secret"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Exact browser origin; do not include a trailing slash. In local development,
# the app accepts both localhost:5173 and 127.0.0.1:5173 loopback aliases.
FRONTEND_ORIGIN="http://127.0.0.1:5173"

UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE_MB=25
MAX_BATCH_SIZE=20

OCR_PROVIDER="gemini"
AI_PROVIDER="gemini"
GEMINI_API_KEY="replace-with-your-gemini-api-key"

# Optional future providers (not currently implemented end-to-end).
OPENAI_API_KEY=""
AZURE_DOCUMENT_INTELLIGENCE_KEY=""
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=""
